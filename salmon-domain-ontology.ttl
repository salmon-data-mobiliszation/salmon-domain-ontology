<https://w3id.org/smn/totalLength> a owl:Class ;
    rdfs:label "Total length"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/FishLength> .

<https://w3id.org/iadopt/ont/Entity> owl:equivalentClass sosa:FeatureOfInterest .

<https://w3id.org/smn/AggregatedMeasurement> a owl:Class ;
    rdfs:label "Aggregated measurement"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/smn/basedOn> ;
            owl:someValuesFrom <https://w3id.org/smn/EnumerationMethod> ],
        <https://w3id.org/smn/Measurement> .

<https://w3id.org/smn/BodyShape> a owl:Class ;
    rdfs:label "Body shape"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/Characteristic> .

<https://w3id.org/smn/ExploitationRate> a owl:Class ;
    rdfs:label "Exploitation rate"@en ;
    ns1:IAO_0000115 "The proportion of returning adult salmon removed by fishing activity over a defined period."@en ;
    ns1:IAO_0000119 "Fisheries and Oceans Canada. Pacific Salmon - Glossary (Pacific Region). https://www.pac.dfo-mpo.gc.ca/fm-gp/salmon-saumon/gloss-eng.html."@en ;
    dcterms:source <https://www.pac.dfo-mpo.gc.ca/fm-gp/salmon-saumon/gloss-eng.html> ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/TargetOrLimitRateOrAbundance> .

<https://w3id.org/smn/FishForkLengthMeasurementMethod> a owl:Class ;
    rdfs:label "Fish fork-length measurement method"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/FishLengthMeasurementMethod> .

<https://w3id.org/smn/FishingType> a owl:Class ;
    rdfs:label "Fishing type"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/EventType> .

<https://w3id.org/smn/GeographicFeature> a owl:Class ;
    rdfs:label "Geographic feature"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf geo:Feature .

<https://w3id.org/smn/Life-HistoryCharacteristic> a owl:Class ;
    rdfs:label "Life-history characteristic"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/Characteristic> .

<https://w3id.org/smn/Observation> a owl:Class ;
    rdfs:label "Observation"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf sosa:Observation .

<https://w3id.org/smn/ReferencePoint> a owl:Class ;
    rdfs:label "Reference point"@en ;
    ns1:IAO_0000115 "A target or limit used to guide management actions."@en ;
    ns1:IAO_0000119 "Fisheries and Oceans Canada. Introduction to Stock Assessment - Glossary. https://www.dfo-mpo.gc.ca/science/species-especes/fisheries-halieutiques/assessment-evaluation/glossary-glossaire/index-eng.html."@en ;
    dcterms:source <https://www.dfo-mpo.gc.ca/science/species-especes/fisheries-halieutiques/assessment-evaluation/glossary-glossaire/index-eng.html> ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf ns1:IAO_0000030 ;
    skos:closeMatch <https://w3id.org/iadopt/ont/Constraint> .

<https://w3id.org/smn/SalmonLifeStage> a owl:Class ;
    rdfs:label "Salmon life stage"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/Characteristic> .

<https://w3id.org/smn/SamplingEvent> a owl:Class ;
    rdfs:label "Sampling event"@en ;
    ns1:IAO_0000115 "A sampling activity that targets a geographic feature, yields a sample, and records a time."@en ;
    rdfs:comment "A sampling activity that targets a geographic feature, yields a sample, and records a time."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom geo:Feature ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom sosa:Sample ],
        [ a owl:Restriction ;
            owl:onProperty sosa:resultTime ;
            owl:someValuesFrom time:Instant ],
        sosa:Sampling .

<https://w3id.org/smn/SurveyEvent> a owl:Class ;
    rdfs:label "Survey event"@en ;
    ns1:IAO_0000115 "A field event that collects information about fish populations to evaluate status and support management decisions."@en ;
    ns1:IAO_0000119 "Fisheries and Oceans Canada. About the Sustainability Survey for Fisheries. https://www.dfo-mpo.gc.ca/reports-rapports/regs/sff-cpd/survey-sondage/about-propos-en.html."@en ;
    dcterms:source <https://www.dfo-mpo.gc.ca/reports-rapports/regs/sff-cpd/survey-sondage/about-propos-en.html> ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <http://rs.tdwg.org/dwc/terms/Event> ;
    skos:closeMatch sosa:Sampling .

<https://w3id.org/smn/TargetOrLimitRateOrAbundance> a owl:Class ;
    rdfs:label "Target or limit rate or abundance"@en ;
    ns1:IAO_0000115 "A value specification representing a policy- or model-defined target or limit."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf ns1:IAO_0000109 .

<https://w3id.org/smn/basedOn> a owl:ObjectProperty ;
    rdfs:label "based on"@en ;
    rdfs:domain <https://w3id.org/smn/AggregatedMeasurement> ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:range <https://w3id.org/smn/EnumerationMethod> .

<https://w3id.org/smn/forkLength> a owl:Class ;
    rdfs:label "Fork length"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/FishLength> .

<https://w3id.org/smn/hasDeme> a owl:ObjectProperty ;
    rdfs:label "has deme"@en ;
    ns1:IAO_0000115 "Relates a population to one of its constituent demes."@en ;
    rdfs:domain <https://w3id.org/smn/Population> ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:range <https://w3id.org/smn/Deme> ;
    rdfs:subPropertyOf ns1:RO_0002351 .

<https://w3id.org/smn/hasPopulation> a owl:ObjectProperty ;
    rdfs:label "has population"@en ;
    ns1:IAO_0000115 "Relates a reporting or management stratum to one of its constituent populations."@en ;
    rdfs:domain <https://w3id.org/smn/ReportingOrManagementStratum> ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:range <https://w3id.org/smn/Population> ;
    rdfs:subPropertyOf ns1:RO_0002351 .

ns1:NCBITaxon_8018 rdfs:subClassOf ns1:NCBITaxon_8015 .

geo:Feature rdfs:subClassOf sosa:FeatureOfInterest .

sosa:Procedure skos:closeMatch <https://rs.tdwg.org/dwc/dp/terms/Protocol> .

sosa:Sample rdfs:comment "Crosswalk used MaterialEntity; aligned here to Darwin Core MaterialSample for concrete publication workflows."@en ;
    owl:equivalentClass <http://rs.tdwg.org/dwc/terms/MaterialSample> ;
    skos:closeMatch <http://rs.tdwg.org/dwc/terms/MaterialEntity> ;
    sosa:isResultOf sosa:Sampling .

<https://w3id.org/iadopt/ont/Constraint> a owl:Class .

<https://w3id.org/smn/Deme> a owl:Class ;
    rdfs:label "Deme"@en ;
    ns1:IAO_0000115 "A local interbreeding group within a species; in salmon systems, typically corresponding to a spawning-site-scale biological unit."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <http://rs.tdwg.org/dwc/terms/Organism> .

<https://w3id.org/smn/EnumerationMethod> a owl:Class ;
    rdfs:label "Enumeration method"@en ;
    ns1:IAO_0000115 "A method used to enumerate or count salmon in the field"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf sosa:Procedure .

<https://w3id.org/smn/EventType> a owl:Class ;
    rdfs:label "Event type"@en ;
    ns1:IAO_0000115 "A class used to categorize fisheries or survey event instances by operational type."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> .

<https://w3id.org/smn/FishLengthMeasurementMethod> a owl:Class ;
    rdfs:label "Fish length measurement method"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf sosa:Procedure .

<https://w3id.org/smn/ForkLengthMeasurementMethod> a owl:Class ;
    rdfs:label "Fork-length measurement method"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/FishForkLengthMeasurementMethod> .

<https://w3id.org/smn/MorphologicalCharacteristic> a owl:Class ;
    rdfs:label "Morphological characteristic"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/Characteristic> .

<https://w3id.org/smn/SalmonGroup> a owl:Class ;
    rdfs:label "Salmon group"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/Entity> .

sosa:Observation owl:equivalentClass <http://rs.tdwg.org/dwc/terms/Occurrence> ;
    skos:closeMatch <http://rs.tdwg.org/dwc/terms/Occurrence> .

<https://w3id.org/smn/FishLengthMeasurementType> a owl:Class ;
    rdfs:label "Fish length measurement type"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:observedProperty ;
            owl:someValuesFrom <https://w3id.org/smn/FishLength> ],
        [ a owl:Restriction ;
            owl:onProperty sosa:usedProcedure ;
            owl:someValuesFrom <https://w3id.org/smn/FishLengthMeasurementMethod> ],
        <https://w3id.org/smn/Measurement> .

<https://w3id.org/smn/ReportingOrManagementStratum> a owl:Class ;
    rdfs:label "Reporting or management stratum"@en ;
    ns1:IAO_0000115 "An information-defined grouping of fish populations used for reporting, conservation assessment, or management purposes across salmon programs."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf ns1:IAO_0000030 ;
    skos:closeMatch sosa:FeatureOfInterest .

<https://w3id.org/smn/SalmonOrigin> a skos:Concept ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    skos:definition "Origin category describing whether salmon are naturally produced, hatchery produced, or mixed-origin."@en ;
    skos:inScheme <https://w3id.org/smn/SalmonOriginScheme> ;
    skos:prefLabel "Salmon origin"@en .

<https://w3id.org/smn/SalmonOriginScheme> a skos:ConceptScheme ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    skos:definition "Controlled vocabulary for describing the origin of individual salmon (e.g., natural-origin, hatchery-origin, mixed-origin)."@en ;
    skos:hasTopConcept <https://w3id.org/smn/SalmonOrigin> ;
    skos:prefLabel "Salmon origin scheme"@en .

sosa:Sampling owl:equivalentClass <http://rs.tdwg.org/dwc/terms/Event> ;
    skos:closeMatch <http://rs.tdwg.org/dwc/terms/Event> .

<https://w3id.org/smn/Entity> a owl:Class ;
    rdfs:label "Entity"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf sosa:FeatureOfInterest,
        <https://w3id.org/iadopt/ont/Entity> .

<https://w3id.org/smn/Population> a owl:Class ;
    rdfs:label "Population"@en ;
    ns1:IAO_0000115 "A group of organisms of the same species occupying a defined area that interbreed and share a gene pool."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <http://rs.tdwg.org/dwc/terms/Organism> .

<https://w3id.org/smn/Characteristic> a owl:Class ;
    rdfs:label "Characteristic"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf sosa:Property .

<https://w3id.org/smn/FishLength> a owl:Class ;
    rdfs:label "Fish length"@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf <https://w3id.org/smn/MorphologicalCharacteristic> .

<https://w3id.org/smn/LifePhase> a skos:Concept ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    skos:definition "A phase or segment used to stratify salmon measurements by where or when they apply (e.g., ocean phase, terminal phase)."@en ;
    skos:inScheme <https://w3id.org/smn/LifePhaseScheme> ;
    skos:prefLabel "Life phase"@en .

<https://w3id.org/smn/LifePhaseScheme> a skos:ConceptScheme ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    skos:definition "Controlled vocabulary for life-phase or fishery/migration segment qualifiers used to stratify measurements (e.g., ocean, terminal, mainstem)."@en ;
    skos:hasTopConcept <https://w3id.org/smn/LifePhase> ;
    skos:prefLabel "Life phase scheme"@en .

<https://w3id.org/smn/Measurement> a owl:Class ;
    rdfs:label "Measurement"@en ;
    ns1:IAO_0000115 "A salmon-domain observation focused on one feature of interest and one characteristic."@en ;
    rdfs:comment "A salmon-domain observation focused on one feature of interest and one characteristic."@en ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom <https://w3id.org/smn/Entity> ],
        [ a owl:Restriction ;
            owl:onProperty sosa:observedProperty ;
            owl:someValuesFrom <https://w3id.org/smn/Characteristic> ],
        <https://w3id.org/smn/Observation> .

<https://w3id.org/smn/MeasurementContext> a skos:Concept ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    skos:definition "A context qualifier used to disambiguate interpretation of a measurement."@en ;
    skos:inScheme <https://w3id.org/smn/MeasurementContextScheme> ;
    skos:prefLabel "Measurement context"@en .

<https://w3id.org/smn/MeasurementContextScheme> a skos:ConceptScheme ;
    rdfs:isDefinedBy <https://w3id.org/smn> ;
    skos:definition "Controlled vocabulary for compositional measurement context qualifiers (for example, catch context, run context)."@en ;
    skos:hasTopConcept <https://w3id.org/smn/MeasurementContext> ;
    skos:prefLabel "Measurement context scheme"@en .

sosa:FeatureOfInterest sosa:hasSample sosa:Sample .

<https://w3id.org/smn> a owl:Ontology ;
    rdfs:label "Salmon Domain Ontology (modular build)"@en ;
    rdfs:comment "Primary modular import graph for reusable salmon-domain concepts and cross-ontology alignments. Phase-1/2/3 scaffold and migration baseline."@en .
