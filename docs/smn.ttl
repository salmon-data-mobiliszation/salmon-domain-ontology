@prefix : <https://w3id.org/smn#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/smn> .

<https://w3id.org/smn> rdf:type owl:Ontology ;
                        rdfs:comment "Conservative shared event taxonomy. Policy/program-specific schemes remain in profile ontologies."@en ,
                                     "Conservative shared stock-assessment and benchmark semantics. Policy-program-specific reference classes remain profile-scoped."@en ,
                                     "Conservative upper-level alignment bridges adapted from DFO Salmon Ontology alignment branch (feat/alignment-modules-main-research)."@en ,
                                     "Core salmon entities, reporting strata, and composition relationships for cross-agency reuse. Includes migrated reusable structure terms from DFO Salmon Ontology (no removals from DFO source)."@en ,
                                     "Cross-ontology bridge statements for SOSA, I-ADOPT, and Darwin Core interoperability."@en ,
                                     "Observation and measurement model (SOSA-aligned) with reusable escapement and survey terms migrated from DFO Salmon Ontology."@en ,
                                     "Primary modular import graph for reusable salmon-domain concepts and cross-ontology alignments. Phase-1/2/3 scaffold and migration baseline."@en ,
                                     "Shared provenance and quality artifact classes. Program-specific confidence vocabularies remain profile-scoped."@en ,
                                     "Small curated shared SKOS layer. Policy/program-specific schemes are profile-scoped by default."@en ;
                        rdfs:label "Salmon Domain Ontology (modular build)"@en ,
                                   "Salmon Domain Ontology Alignment Module (main-candidate)"@en ,
                                   "Salmon Domain Ontology Module 01: Entity and systematics"@en ,
                                   "Salmon Domain Ontology Module 02: Observation and measurement"@en ,
                                   "Salmon Domain Ontology Module 03: Assessment and benchmarks"@en ,
                                   "Salmon Domain Ontology Module 04: Management and governance"@en ,
                                   "Salmon Domain Ontology Module 05: Provenance and quality"@en ,
                                   "Salmon Domain Ontology Module 06: Data interoperability"@en ,
                                   "Salmon Domain Ontology Module 07: Controlled vocabularies"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.obolibrary.org/obo/IAO_0000115
ns1:IAO_0000115 rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#hasTopConcept
skos:hasTopConcept rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/sosa/hasSample
sosa:hasSample rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/sosa/isResultOf
sosa:isResultOf rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/RO_0002351
ns1:RO_0002351 rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/hasFeatureOfInterest
sosa:hasFeatureOfInterest rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/hasResult
sosa:hasResult rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/observedProperty
sosa:observedProperty rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/resultTime
sosa:resultTime rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/usedProcedure
sosa:usedProcedure rdf:type owl:ObjectProperty .


###  https://w3id.org/smn/basedOn
<https://w3id.org/smn/basedOn> rdf:type owl:ObjectProperty ;
                               rdfs:domain <https://w3id.org/smn/AggregatedMeasurement> ;
                               rdfs:range <https://w3id.org/smn/EnumerationMethod> ;
                               rdfs:label "based on"@en .


###  https://w3id.org/smn/characteristicFor
<https://w3id.org/smn/characteristicFor> rdf:type owl:ObjectProperty ;
                                         rdfs:domain sosa:Property ;
                                         rdfs:range sosa:FeatureOfInterest ;
                                         rdfs:label "characteristic for"@en .


###  https://w3id.org/smn/demeOf
<https://w3id.org/smn/demeOf> rdf:type owl:ObjectProperty ;
                              owl:inverseOf <https://w3id.org/smn/hasDeme> ;
                              rdfs:domain <https://w3id.org/smn/Deme> ;
                              rdfs:range <https://w3id.org/smn/Population> ;
                              ns1:IAO_0000115 "Relates a deme to the population it belongs to."@en ;
                              rdfs:label "deme of"@en .


###  https://w3id.org/smn/hasDeme
<https://w3id.org/smn/hasDeme> rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf ns1:RO_0002351 ;
                               rdfs:domain <https://w3id.org/smn/Population> ;
                               rdfs:range <https://w3id.org/smn/Deme> ;
                               ns1:IAO_0000115 "Relates a population to one of its constituent demes."@en ;
                               rdfs:label "has deme"@en .


###  https://w3id.org/smn/hasEventType
<https://w3id.org/smn/hasEventType> rdf:type owl:ObjectProperty ;
                                    rdfs:domain <https://w3id.org/smn/SamplingEvent> ;
                                    rdfs:range <https://w3id.org/smn/EventType> ;
                                    rdfs:label "has event type"@en .


###  https://w3id.org/smn/hasMeasurement
<https://w3id.org/smn/hasMeasurement> rdf:type owl:ObjectProperty ;
                                      rdfs:domain sosa:FeatureOfInterest ;
                                      rdfs:range <https://w3id.org/smn/Measurement> ;
                                      rdfs:label "has measurement"@en .


###  https://w3id.org/smn/hasPopulation
<https://w3id.org/smn/hasPopulation> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf ns1:RO_0002351 ;
                                     owl:inverseOf <https://w3id.org/smn/populationOf> ;
                                     rdfs:domain <https://w3id.org/smn/ReportingOrManagementStratum> ;
                                     rdfs:range <https://w3id.org/smn/Population> ;
                                     ns1:IAO_0000115 "Relates a reporting or management stratum to one of its constituent populations."@en ;
                                     rdfs:label "has population"@en .


###  https://w3id.org/smn/observedTaxonFamily
<https://w3id.org/smn/observedTaxonFamily> rdf:type owl:ObjectProperty ;
                                           rdfs:domain sosa:Observation ;
                                           rdfs:range ns1:NCBITaxon_8015 ;
                                           rdfs:label "observed taxon family"@en .


###  https://w3id.org/smn/observedTaxonSpecies
<https://w3id.org/smn/observedTaxonSpecies> rdf:type owl:ObjectProperty ;
                                            rdfs:domain sosa:Observation ;
                                            rdfs:range ns1:NCBITaxon_8018 ;
                                            rdfs:label "observed taxon species"@en .


###  https://w3id.org/smn/populationOf
<https://w3id.org/smn/populationOf> rdf:type owl:ObjectProperty ;
                                    rdfs:domain <https://w3id.org/smn/Population> ;
                                    rdfs:range <https://w3id.org/smn/ReportingOrManagementStratum> ;
                                    ns1:IAO_0000115 "Relates a population to the reporting or management stratum it belongs to."@en ;
                                    rdfs:label "population of"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000015
ns1:BFO_0000015 rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/IAO_0000030
ns1:IAO_0000030 rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/IAO_0000109
ns1:IAO_0000109 rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/NCBITaxon_8015
ns1:NCBITaxon_8015 rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/NCBITaxon_8018
ns1:NCBITaxon_8018 rdf:type owl:Class ;
                   rdfs:subClassOf ns1:NCBITaxon_8015 .


###  http://rs.tdwg.org/dwc/terms/Event
<http://rs.tdwg.org/dwc/terms/Event> rdf:type owl:Class ;
                                     owl:equivalentClass sosa:Sampling .


###  http://rs.tdwg.org/dwc/terms/MaterialSample
<http://rs.tdwg.org/dwc/terms/MaterialSample> rdf:type owl:Class ;
                                              owl:equivalentClass sosa:Sample .


###  http://rs.tdwg.org/dwc/terms/Occurrence
<http://rs.tdwg.org/dwc/terms/Occurrence> rdf:type owl:Class ;
                                          owl:equivalentClass sosa:Observation .


###  http://rs.tdwg.org/dwc/terms/Organism
<http://rs.tdwg.org/dwc/terms/Organism> rdf:type owl:Class .


###  http://www.opengis.net/ont/geosparql#Feature
geo:Feature rdf:type owl:Class ;
            rdfs:subClassOf sosa:FeatureOfInterest .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .


###  http://www.w3.org/2006/time#Instant
time:Instant rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/FeatureOfInterest
sosa:FeatureOfInterest rdf:type owl:Class ;
                       owl:equivalentClass <https://w3id.org/iadopt/ont/Entity> ;
                       sosa:hasSample sosa:Sample .


###  http://www.w3.org/ns/sosa/Observation
sosa:Observation rdf:type owl:Class ;
                 skos:closeMatch <http://rs.tdwg.org/dwc/terms/Occurrence> .


###  http://www.w3.org/ns/sosa/Procedure
sosa:Procedure rdf:type owl:Class ;
               skos:closeMatch <https://rs.tdwg.org/dwc/dp/terms/Protocol> .


###  http://www.w3.org/ns/sosa/Property
sosa:Property rdf:type owl:Class ;
              owl:equivalentClass <https://w3id.org/iadopt/ont/Property> .


###  http://www.w3.org/ns/sosa/Sample
sosa:Sample rdf:type owl:Class ;
            rdfs:comment "Crosswalk used MaterialEntity; aligned here to Darwin Core MaterialSample for concrete publication workflows."@en ;
            skos:closeMatch <http://rs.tdwg.org/dwc/terms/MaterialEntity> ;
            sosa:isResultOf sosa:Sampling .


###  http://www.w3.org/ns/sosa/Sampling
sosa:Sampling rdf:type owl:Class ;
              skos:closeMatch <http://rs.tdwg.org/dwc/terms/Event> .


###  https://w3id.org/iadopt/ont/Constraint
<https://w3id.org/iadopt/ont/Constraint> rdf:type owl:Class .


###  https://w3id.org/iadopt/ont/Entity
<https://w3id.org/iadopt/ont/Entity> rdf:type owl:Class .


###  https://w3id.org/iadopt/ont/Property
<https://w3id.org/iadopt/ont/Property> rdf:type owl:Class .


###  https://w3id.org/iadopt/ont/StatisticalModifier
<https://w3id.org/iadopt/ont/StatisticalModifier> rdf:type owl:Class .


###  https://w3id.org/iadopt/ont/Variable
<https://w3id.org/iadopt/ont/Variable> rdf:type owl:Class .


###  https://w3id.org/smn/AggregatedMeasurement
<https://w3id.org/smn/AggregatedMeasurement> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/smn/Measurement> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://w3id.org/smn/basedOn> ;
                                                               owl:someValuesFrom <https://w3id.org/smn/EnumerationMethod>
                                                             ] ;
                                             rdfs:label "Aggregated measurement"@en .


###  https://w3id.org/smn/BodyShape
<https://w3id.org/smn/BodyShape> rdf:type owl:Class ;
                                 rdfs:subClassOf <https://w3id.org/smn/Characteristic> ;
                                 rdfs:label "Body shape"@en .


###  https://w3id.org/smn/Characteristic
<https://w3id.org/smn/Characteristic> rdf:type owl:Class ;
                                      rdfs:subClassOf sosa:Property ;
                                      rdfs:label "Characteristic"@en .


###  https://w3id.org/smn/DataQualityAssessment
<https://w3id.org/smn/DataQualityAssessment> rdf:type owl:Class ;
                                             rdfs:subClassOf ns1:IAO_0000030 ;
                                             ns1:IAO_0000115 "An assessment artifact describing confidence, uncertainty, and quality constraints for a salmon data product or metric."@en ;
                                             rdfs:label "Data quality assessment"@en .


###  https://w3id.org/smn/Deme
<https://w3id.org/smn/Deme> rdf:type owl:Class ;
                            rdfs:subClassOf <http://rs.tdwg.org/dwc/terms/Organism> ;
                            ns1:IAO_0000115 "A local interbreeding group within a species; in salmon systems, typically corresponding to a spawning-site-scale biological unit."@en ;
                            rdfs:label "Deme"@en .


###  https://w3id.org/smn/Entity
<https://w3id.org/smn/Entity> rdf:type owl:Class ;
                              rdfs:subClassOf sosa:FeatureOfInterest ,
                                              <https://w3id.org/iadopt/ont/Entity> ;
                              rdfs:label "Entity"@en .


###  https://w3id.org/smn/EnumerationMethod
<https://w3id.org/smn/EnumerationMethod> rdf:type owl:Class ;
                                         rdfs:subClassOf sosa:Procedure ;
                                         rdfs:label "Enumeration method"@en .


###  https://w3id.org/smn/Escapement
<https://w3id.org/smn/Escapement> rdf:type owl:Class ;
                                  rdfs:subClassOf ns1:BFO_0000015 ;
                                  ns1:IAO_0000115 "The number of mature salmon that pass through (or escape) fisheries and return to fresh water to spawn."@en ;
                                  rdfs:label "Escapement"@en .


###  https://w3id.org/smn/EscapementMeasurement
<https://w3id.org/smn/EscapementMeasurement> rdf:type owl:Class ;
                                             rdfs:subClassOf ns1:IAO_0000109 ;
                                             ns1:IAO_0000115 "A measurement or estimate of escapement tied to a stock and a survey event."@en ;
                                             rdfs:label "Escapement measurement"@en ;
                                             skos:closeMatch sosa:Result .


###  https://w3id.org/smn/EscapementSurveyEvent
<https://w3id.org/smn/EscapementSurveyEvent> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/smn/SurveyEvent> ;
                                             ns1:IAO_0000115 "A survey event specifically for estimating escapement."@en ;
                                             rdfs:label "Escapement survey event"@en ;
                                             skos:closeMatch sosa:Sampling .


###  https://w3id.org/smn/EventType
<https://w3id.org/smn/EventType> rdf:type owl:Class ;
                                 ns1:IAO_0000115 "A class used to categorize fisheries or survey event instances by operational type."@en ;
                                 rdfs:label "Event type"@en .


###  https://w3id.org/smn/ExploitationRate
<https://w3id.org/smn/ExploitationRate> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/smn/TargetOrLimitRateOrAbundance> ;
                                        ns1:IAO_0000115 "The proportion of returning adult salmon removed by fishing activity over a defined period."@en ;
                                        rdfs:label "Exploitation rate"@en .


###  https://w3id.org/smn/FishForkLengthMeasurementMethod
<https://w3id.org/smn/FishForkLengthMeasurementMethod> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://w3id.org/smn/FishLengthMeasurementMethod> ;
                                                       rdfs:label "Fish fork-length measurement method"@en .


###  https://w3id.org/smn/FishLength
<https://w3id.org/smn/FishLength> rdf:type owl:Class ;
                                  owl:equivalentClass <https://w3id.org/smn/forkLength> ;
                                  rdfs:subClassOf <https://w3id.org/smn/MorphologicalCharacteristic> ;
                                  rdfs:label "Fish length"@en .


###  https://w3id.org/smn/FishLengthMeasurementMethod
<https://w3id.org/smn/FishLengthMeasurementMethod> rdf:type owl:Class ;
                                                   rdfs:subClassOf sosa:Procedure ;
                                                   rdfs:label "Fish length measurement method"@en .


###  https://w3id.org/smn/FishLengthMeasurementType
<https://w3id.org/smn/FishLengthMeasurementType> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://w3id.org/smn/Measurement> ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty sosa:observedProperty ;
                                                                   owl:someValuesFrom <https://w3id.org/smn/FishLength>
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty sosa:usedProcedure ;
                                                                   owl:someValuesFrom <https://w3id.org/smn/FishLengthMeasurementMethod>
                                                                 ] ;
                                                 rdfs:label "Fish length measurement type"@en .


###  https://w3id.org/smn/FishWeight
<https://w3id.org/smn/FishWeight> rdf:type owl:Class ;
                                  rdfs:subClassOf <https://w3id.org/smn/MorphologicalCharacteristic> ;
                                  rdfs:label "Fish weight"@en .


###  https://w3id.org/smn/FishingType
<https://w3id.org/smn/FishingType> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/smn/EventType> ;
                                   rdfs:label "Fishing type"@en .


###  https://w3id.org/smn/ForkLengthMeasurement
<https://w3id.org/smn/ForkLengthMeasurement> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/smn/FishLengthMeasurementType> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty sosa:observedProperty ;
                                                               owl:someValuesFrom <https://w3id.org/smn/forkLength>
                                                             ] ;
                                             rdfs:label "Fork-length measurement"@en .


###  https://w3id.org/smn/ForkLengthMeasurementFieldMethod
<https://w3id.org/smn/ForkLengthMeasurementFieldMethod> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://w3id.org/smn/ForkLengthMeasurementMethod> ;
                                                        rdfs:label "Fork-length field method"@en .


###  https://w3id.org/smn/ForkLengthMeasurementLabMethod
<https://w3id.org/smn/ForkLengthMeasurementLabMethod> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/smn/ForkLengthMeasurementMethod> ;
                                                      rdfs:label "Fork-length lab method"@en .


###  https://w3id.org/smn/ForkLengthMeasurementMethod
<https://w3id.org/smn/ForkLengthMeasurementMethod> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/smn/FishForkLengthMeasurementMethod> ;
                                                   rdfs:label "Fork-length measurement method"@en .


###  https://w3id.org/smn/GeographicFeature
<https://w3id.org/smn/GeographicFeature> rdf:type owl:Class ;
                                         rdfs:subClassOf geo:Feature ;
                                         rdfs:label "Geographic feature"@en .


###  https://w3id.org/smn/HabitatUnit
<https://w3id.org/smn/HabitatUnit> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/smn/Entity> ;
                                   rdfs:label "Habitat unit"@en .


###  https://w3id.org/smn/IndicatorRiver
<https://w3id.org/smn/IndicatorRiver> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/smn/GeographicFeature> ;
                                      ns1:IAO_0000115 "A river or stream used as a relatively reliable abundance index for nearby salmon returns due to survey intensity and method quality."@en ;
                                      dcterms:source <https://www.salmonexplorer.ca/methods/glossary.html> ;
                                      rdfs:label "Indicator river"@en ;
                                      skos:altLabel "Indicator stream"@en ;
                                      skos:closeMatch sosa:FeatureOfInterest .


###  https://w3id.org/smn/IndividualMeasurement
<https://w3id.org/smn/IndividualMeasurement> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/smn/Measurement> ;
                                             rdfs:label "Individual measurement"@en .


###  https://w3id.org/smn/Life-HistoryCharacteristic
<https://w3id.org/smn/Life-HistoryCharacteristic> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://w3id.org/smn/Characteristic> ;
                                                  rdfs:label "Life-history characteristic"@en .


###  https://w3id.org/smn/LimitReferencePoint
<https://w3id.org/smn/LimitReferencePoint> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://w3id.org/smn/ReferencePoint> ;
                                           ns1:IAO_0000115 "A lower threshold indicating stock status where stronger mitigation or rebuilding action is triggered."@en ;
                                           rdfs:label "Limit reference point"@en .


###  https://w3id.org/smn/LowerBiologicalBenchmark
<https://w3id.org/smn/LowerBiologicalBenchmark> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/smn/MetricBenchmark> ;
                                                ns1:IAO_0000115 "Lower benchmark value used to delineate lower status boundaries for salmon assessment units."@en ;
                                                rdfs:label "Lower biological benchmark"@en ;
                                                skos:closeMatch <https://w3id.org/iadopt/ont/Constraint> .


###  https://w3id.org/smn/Measurement
<https://w3id.org/smn/Measurement> rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/smn/Observation> ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty sosa:hasFeatureOfInterest ;
                                                     owl:someValuesFrom <https://w3id.org/smn/Entity>
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty sosa:observedProperty ;
                                                     owl:someValuesFrom <https://w3id.org/smn/Characteristic>
                                                   ] ;
                                   rdfs:comment "A salmon-domain observation focused on one feature of interest and one characteristic."@en ;
                                   rdfs:label "Measurement"@en .


###  https://w3id.org/smn/MethodDocumentation
<https://w3id.org/smn/MethodDocumentation> rdf:type owl:Class ;
                                           rdfs:subClassOf ns1:IAO_0000030 ;
                                           ns1:IAO_0000115 "A documented method description linked to how a salmon metric or estimate was produced."@en ;
                                           rdfs:label "Method documentation"@en .


###  https://w3id.org/smn/MetricBenchmark
<https://w3id.org/smn/MetricBenchmark> rdf:type owl:Class ;
                                       rdfs:subClassOf ns1:IAO_0000030 ;
                                       ns1:IAO_0000115 "Benchmark value for a metric used to delineate status categories."@en ;
                                       dcterms:source <https://publications.gc.ca/site/eng/9.928944/publication.html> ;
                                       rdfs:label "Metric benchmark"@en .


###  https://w3id.org/smn/ModelMeasurement
<https://w3id.org/smn/ModelMeasurement> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://w3id.org/smn/Measurement> ;
                                        rdfs:label "Model measurement"@en .


###  https://w3id.org/smn/MorphologicalCharacteristic
<https://w3id.org/smn/MorphologicalCharacteristic> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/smn/Characteristic> ;
                                                   rdfs:label "Morphological characteristic"@en .


###  https://w3id.org/smn/NCBITaxon_8018
<https://w3id.org/smn/NCBITaxon_8018> rdf:type owl:Class ;
                                      rdfs:subClassOf ns1:NCBITaxon_8018 ;
