        <skos:inScheme rdf:resource="https://w3id.org/smn/LifePhaseScheme"/>
        <skos:prefLabel xml:lang="en">In-river phase</skos:prefLabel>
    </owl:NamedIndividual>



    <!-- https://w3id.org/smn/LifePhase -->

