    </owl:Class>



    <!-- http://www.w3.org/ns/sosa/Property -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Property">
        <owl:equivalentClass rdf:resource="https://w3id.org/iadopt/ont/Property"/>
    </owl:Class>



    <!-- http://www.w3.org/ns/sosa/Sample -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sample">
        <rdfs:comment xml:lang="en">Crosswalk used MaterialEntity; aligned here to Darwin Core MaterialSample for concrete publication workflows.</rdfs:comment>
        <skos:closeMatch rdf:resource="http://rs.tdwg.org/dwc/terms/MaterialEntity"/>
        <sosa:isResultOf rdf:resource="http://www.w3.org/ns/sosa/Sampling"/>
    </owl:Class>



    <!-- http://www.w3.org/ns/sosa/Sampling -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sampling">
        <skos:closeMatch rdf:resource="http://rs.tdwg.org/dwc/terms/Event"/>
    </owl:Class>



    <!-- https://w3id.org/iadopt/ont/Constraint -->

    <owl:Class rdf:about="https://w3id.org/iadopt/ont/Constraint"/>



    <!-- https://w3id.org/iadopt/ont/Entity -->

    <owl:Class rdf:about="https://w3id.org/iadopt/ont/Entity"/>



    <!-- https://w3id.org/iadopt/ont/Property -->

    <owl:Class rdf:about="https://w3id.org/iadopt/ont/Property"/>



    <!-- https://w3id.org/iadopt/ont/StatisticalModifier -->

    <owl:Class rdf:about="https://w3id.org/iadopt/ont/StatisticalModifier"/>



    <!-- https://w3id.org/iadopt/ont/Variable -->

    <owl:Class rdf:about="https://w3id.org/iadopt/ont/Variable"/>



    <!-- https://w3id.org/smn/AggregatedMeasurement -->

    <owl:Class rdf:about="https://w3id.org/smn/AggregatedMeasurement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/smn/Measurement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/smn/basedOn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/smn/EnumerationMethod"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Aggregated measurement</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/BodyShape -->

    <owl:Class rdf:about="https://w3id.org/smn/BodyShape">
        <rdfs:subClassOf rdf:resource="https://w3id.org/smn/Characteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Body shape</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/CatchAbundance -->

    <owl:Class rdf:about="https://w3id.org/smn/CatchAbundance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/smn/ObservedRateOrAbundance"/>
        <ns1:IAO_0000115 xml:lang="en">A measurement datum recording the number of salmon represented in fishery catch for a defined fishery, place, time, or stock context.</ns1:IAO_0000115>
        <ns1:IAO_0000119 xml:lang="en">Fisheries and Oceans Canada. Pacific Salmon - Glossary (Pacific Region). https://www.pac.dfo-mpo.gc.ca/fm-gp/salmon-saumon/gloss-eng.html.</ns1:IAO_0000119>
        <dcterms:source rdf:resource="https://www.pac.dfo-mpo.gc.ca/fm-gp/salmon-saumon/gloss-eng.html"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Catch abundance</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/Characteristic -->

    <owl:Class rdf:about="https://w3id.org/smn/Characteristic">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Property"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Characteristic</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/DataQualityAssessment -->

    <owl:Class rdf:about="https://w3id.org/smn/DataQualityAssessment">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <ns1:IAO_0000115 xml:lang="en">An assessment artifact describing confidence, uncertainty, and quality constraints for a salmon data product or metric.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Data quality assessment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/Deme -->

    <owl:Class rdf:about="https://w3id.org/smn/Deme">
        <rdfs:subClassOf rdf:resource="http://rs.tdwg.org/dwc/terms/Organism"/>
        <ns1:IAO_0000115 xml:lang="en">A local interbreeding group within a species; in salmon systems, typically corresponding to a spawning-site-scale biological unit.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Deme</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/Entity -->

    <owl:Class rdf:about="https://w3id.org/smn/Entity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/iadopt/ont/Entity"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Entity</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/EnumerationMethod -->

    <owl:Class rdf:about="https://w3id.org/smn/EnumerationMethod">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Procedure"/>
        <ns1:IAO_0000115 xml:lang="en">A method used to enumerate or count salmon in the field</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Enumeration method</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/Escapement -->

    <owl:Class rdf:about="https://w3id.org/smn/Escapement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <ns1:IAO_0000115 xml:lang="en">The number of mature salmon that pass through (or escape) fisheries and return to fresh water to spawn.</ns1:IAO_0000115>
        <ns1:IAO_0000119 xml:lang="en">Fisheries and Oceans Canada. 2005. Canada&apos;s Policy for Conservation of Wild Pacific Salmon. https://waves-vagues.dfo-mpo.gc.ca/library-bibliotheque/315577.pdf.</ns1:IAO_0000119>
        <dcterms:source rdf:resource="https://waves-vagues.dfo-mpo.gc.ca/library-bibliotheque/315577.pdf"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Escapement</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/smn/EscapementMeasurement -->

    <owl:Class rdf:about="https://w3id.org/smn/EscapementMeasurement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <ns1:IAO_0000115 xml:lang="en">A measurement or estimate of escapement tied to a stock and a survey event.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">Escapement measurement</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/Result"/>
    </owl:Class>



    <!-- https://w3id.org/smn/EscapementSurveyEvent -->

