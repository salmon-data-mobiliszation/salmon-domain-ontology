    <!-- https://w3id.org/smn/basedOn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/basedOn">
        <rdfs:domain rdf:resource="https://w3id.org/smn/AggregatedMeasurement"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/EnumerationMethod"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">based on</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/characteristicFor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/characteristicFor">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Property"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">characteristic for</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/demeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/demeOf">
        <owl:inverseOf rdf:resource="https://w3id.org/smn/hasDeme"/>
        <rdfs:domain rdf:resource="https://w3id.org/smn/Deme"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/Population"/>
        <ns1:IAO_0000115 xml:lang="en">Relates a deme to the population it belongs to.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">deme of</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/hasDeme -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/hasDeme">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
        <rdfs:domain rdf:resource="https://w3id.org/smn/Population"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/Deme"/>
        <ns1:IAO_0000115 xml:lang="en">Relates a population to one of its constituent demes.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">has deme</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/hasEventType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/hasEventType">
        <rdfs:domain rdf:resource="https://w3id.org/smn/SamplingEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/EventType"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">has event type</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/hasMeasurement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/hasMeasurement">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/Measurement"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">has measurement</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/hasPopulation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/hasPopulation">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
        <owl:inverseOf rdf:resource="https://w3id.org/smn/populationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/smn/ReportingOrManagementStratum"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/Population"/>
        <ns1:IAO_0000115 xml:lang="en">Relates a reporting or management stratum to one of its constituent populations.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">has population</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/observedTaxonFamily -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/observedTaxonFamily">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_8015"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">observed taxon family</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/observedTaxonSpecies -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/observedTaxonSpecies">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_8018"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">observed taxon species</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/smn/populationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/smn/populationOf">
        <rdfs:domain rdf:resource="https://w3id.org/smn/Population"/>
        <rdfs:range rdf:resource="https://w3id.org/smn/ReportingOrManagementStratum"/>
        <ns1:IAO_0000115 xml:lang="en">Relates a population to the reporting or management stratum it belongs to.</ns1:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/smn"/>
        <rdfs:label xml:lang="en">population of</rdfs:label>
    </owl:ObjectProperty>



