@prefix hakai: <https://w3id.org/smn/profile/hakai/> .
@prefix rda: <https://w3id.org/smn/profile/rda-case-study/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

hakai:Fork_Length_Measurement_Method a skos:Concept ;
  skos:prefLabel "Fork Length Measurement Method"@en ;
  skos:inScheme rda:HakaiJSPMeasurementTermScheme ;
  skos:definition "Hakai source term representing fork-length measurement method in case-study mapping."@en ;
  skos:closeMatch smn:FishForkLengthMeasurementMethod ;
  prov:wasDerivedFrom <https://drive.google.com/file/d/1-WPKX6XwDiyLGZGT-bcF36N4ankpNi1o/view> .

