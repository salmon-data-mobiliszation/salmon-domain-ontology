  skos:inScheme rda:HakaiJSPMeasurementTermScheme ;
  skos:closeMatch smn:ForkLengthMeasurementFieldMethod ;
  prov:wasDerivedFrom <https://drive.google.com/file/d/1-WPKX6XwDiyLGZGT-bcF36N4ankpNi1o/view> .

hakai:fork_length_measurement_lab_method a skos:Concept ;
  skos:prefLabel "fork_length_measurement_lab_method"@en ;
  skos:inScheme rda:HakaiJSPMeasurementTermScheme ;
  skos:closeMatch smn:ForkLengthMeasurementLabMethod ;
  prov:wasDerivedFrom <https://drive.google.com/file/d/1-WPKX6XwDiyLGZGT-bcF36N4ankpNi1o/view> .

hakai:Fork_Length_Field_Measurement a skos:Concept ;
  skos:prefLabel "Fork Length Field Measurement"@en ;
  skos:inScheme rda:HakaiJSPMeasurementTermScheme ;
  skos:closeMatch smn:ForkLengthMeasurement ;
  skos:note "Graph label appears as hakai:Fork_Length_Field_Measurement in yEd export."@en ;
  prov:wasDerivedFrom <https://drive.google.com/file/d/1-WPKX6XwDiyLGZGT-bcF36N4ankpNi1o/view> .

hakai:Fork_Length_Lab_Measurement a skos:Concept ;
