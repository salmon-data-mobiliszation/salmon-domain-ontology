# NOTE: edit this file and regenerate the assembled module via scripts/build_rda_case_study_modules.py

@prefix smn: <https://w3id.org/smn/> .
@prefix neville: <https://w3id.org/smn/profile/neville/> .
@prefix rda: <https://w3id.org/smn/profile/rda-case-study/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

neville:Length_mm a skos:Concept ;
  skos:prefLabel "Length (mm)"@en ;
  skos:definition "Fork length measurement in millimetres."@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:closeMatch smn:forkLength ;
  prov:wasDerivedFrom <https://docs.google.com/spreadsheets/d/10Bd7bhTJvOOr-V1wK6YyAj9A4PvxKKpumEvcyIobBlw/edit> .

neville:Weight_g a skos:Concept ;
  skos:prefLabel "Weight (g)"@en ;
  skos:definition "Body mass measurement in grams."@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:closeMatch smn:FishWeight ;
  prov:wasDerivedFrom <https://docs.google.com/spreadsheets/d/10Bd7bhTJvOOr-V1wK6YyAj9A4PvxKKpumEvcyIobBlw/edit> .

neville:AverageConditionFactor a skos:Concept ;
  skos:prefLabel "Average Condition Factor"@en ;
  skos:definition "Derived Fulton's K condition factor (K = 10^5 * W / L^3)."@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:relatedMatch smn:AggregatedMeasurement ;
  skos:relatedMatch smn:FishWeight ;
  skos:relatedMatch smn:forkLength ;
  prov:wasDerivedFrom <https://docs.google.com/spreadsheets/d/10Bd7bhTJvOOr-V1wK6YyAj9A4PvxKKpumEvcyIobBlw/edit> .

neville:ADCWT a skos:Concept ;
  skos:prefLabel "ADCWT"@en ;
  skos:definition "Coded-wire-tag related value in the Neville decomposition context."@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:relatedMatch smn:Observation .

neville:WoundsParasitesOther a skos:Concept ;
  skos:prefLabel "Wounds, Parasites, Other"@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:relatedMatch smn:Observation .

neville:AverageLength_mm a skos:Concept ;
  skos:prefLabel "Average Length (mm)"@en ;
  skos:definition "Average fork length for a juvenile salmon subset in a defined spatial-temporal extent."@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:closeMatch smn:AggregatedMeasurement ;
  skos:relatedMatch smn:forkLength .

neville:AverageWeight_g a skos:Concept ;
  skos:prefLabel "Average Weight (g)"@en ;
  skos:inScheme rda:NevilleDecompositionTermScheme ;
  skos:closeMatch smn:AggregatedMeasurement ;
  skos:relatedMatch smn:FishWeight .

