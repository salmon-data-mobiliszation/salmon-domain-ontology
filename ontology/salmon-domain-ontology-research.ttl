@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://w3id.org/smn/research> a owl:Ontology ;
  rdfs:label "Salmon Domain Ontology (research alignment build)"@en ;
  rdfs:comment "Research build that layers exploratory alignment axioms on top of the conservative modular salmon-domain ontology."@en ;
  owl:imports
    <https://w3id.org/smn>,
    <https://w3id.org/smn/modules/alignment-research> .
