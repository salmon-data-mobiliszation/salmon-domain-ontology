@prefix smn: <https://w3id.org/smn/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix dwc: <http://rs.tdwg.org/dwc/terms/> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix iao: <http://purl.obolibrary.org/obo/IAO_> .

<https://w3id.org/smn/modules/02-observation-measurement> a owl:Ontology ;
  rdfs:label "Salmon Domain Ontology Module 02: Observation and measurement"@en ;
  rdfs:comment "Observation and measurement model (SOSA-aligned) with reusable escapement and survey terms migrated from DFO Salmon Ontology."@en .

#################################################################
# Observation and measurement classes (existing salmon-domain terms)
#################################################################

smn:Observation a owl:Class ;
  rdfs:label "Observation"@en ;
  rdfs:subClassOf sosa:Observation .

smn:Characteristic a owl:Class ;
  rdfs:label "Characteristic"@en ;
  rdfs:subClassOf sosa:Property .

smn:MorphologicalCharacteristic a owl:Class ;
  rdfs:label "Morphological characteristic"@en ;
  rdfs:subClassOf smn:Characteristic .

smn:FishLength a owl:Class ;
  rdfs:label "Fish length"@en ;
  rdfs:subClassOf smn:MorphologicalCharacteristic .

smn:forkLength a owl:Class ;
  rdfs:label "Fork length"@en ;
  owl:equivalentClass smn:FishLength .

smn:standardLength a owl:Class ;
  rdfs:label "Standard length"@en ;
  rdfs:subClassOf smn:FishLength .

smn:totalLength a owl:Class ;
  rdfs:label "Total length"@en ;
  rdfs:subClassOf smn:FishLength .

smn:orbitalLength a owl:Class ;
  rdfs:label "Orbital length"@en ;
  rdfs:subClassOf smn:FishLength .

smn:FishWeight a owl:Class ;
  rdfs:label "Fish weight"@en ;
  rdfs:subClassOf smn:MorphologicalCharacteristic .

smn:BodyShape a owl:Class ;
  rdfs:label "Body shape"@en ;
  rdfs:subClassOf smn:Characteristic .

smn:SalmonLifeStage a owl:Class ;
  rdfs:label "Salmon life stage"@en ;
  rdfs:subClassOf smn:Characteristic .

smn:Life-HistoryCharacteristic a owl:Class ;
  rdfs:label "Life-history characteristic"@en ;
  rdfs:subClassOf smn:Characteristic .

smn:fusiform a owl:Class ;
  rdfs:label "Fusiform"@en ;
  rdfs:subClassOf smn:BodyShape .

smn:alevin a owl:Class ;
  rdfs:label "Alevin"@en ;
  rdfs:subClassOf smn:SalmonLifeStage .

smn:Run a owl:Class ;
  rdfs:label "Run"@en ;
  rdfs:subClassOf smn:Life-HistoryCharacteristic .

smn:FishLengthMeasurementMethod a owl:Class ;
  rdfs:label "Fish length measurement method"@en ;
  rdfs:subClassOf sosa:Procedure .

smn:FishForkLengthMeasurementMethod a owl:Class ;
  rdfs:label "Fish fork-length measurement method"@en ;
  rdfs:subClassOf smn:FishLengthMeasurementMethod .

smn:ForkLengthMeasurementMethod a owl:Class ;
  rdfs:label "Fork-length measurement method"@en ;
  rdfs:subClassOf smn:FishForkLengthMeasurementMethod .

smn:ForkLengthMeasurementFieldMethod a owl:Class ;
  rdfs:label "Fork-length field method"@en ;
  rdfs:subClassOf smn:ForkLengthMeasurementMethod .

smn:ForkLengthMeasurementLabMethod a owl:Class ;
  rdfs:label "Fork-length lab method"@en ;
  rdfs:subClassOf smn:ForkLengthMeasurementMethod .

smn:EnumerationMethod a owl:Class ;
  rdfs:label "Enumeration method"@en ;
  rdfs:subClassOf sosa:Procedure .

smn:Measurement a owl:Class ;
  rdfs:label "Measurement"@en ;
  rdfs:comment "A salmon-domain observation focused on one feature of interest and one characteristic."@en ;
  rdfs:subClassOf smn:Observation ,
    [ a owl:Restriction ;
      owl:onProperty sosa:hasFeatureOfInterest ;
      owl:someValuesFrom smn:Entity ],
    [ a owl:Restriction ;
      owl:onProperty sosa:observedProperty ;
      owl:someValuesFrom smn:Characteristic ] .

smn:FishLengthMeasurementType a owl:Class ;
  rdfs:label "Fish length measurement type"@en ;
  rdfs:subClassOf smn:Measurement ,
    [ a owl:Restriction ;
      owl:onProperty sosa:observedProperty ;
      owl:someValuesFrom smn:FishLength ],
    [ a owl:Restriction ;
      owl:onProperty sosa:usedProcedure ;
      owl:someValuesFrom smn:FishLengthMeasurementMethod ] .

smn:ForkLengthMeasurement a owl:Class ;
  rdfs:label "Fork-length measurement"@en ;
  rdfs:subClassOf smn:FishLengthMeasurementType ,
    [ a owl:Restriction ;
      owl:onProperty sosa:observedProperty ;
      owl:someValuesFrom smn:forkLength ] .

smn:StandardLengthMeasurement a owl:Class ;
  rdfs:label "Standard length measurement"@en ;
  rdfs:subClassOf smn:FishLengthMeasurementType .

smn:TotalLengthMeasurement a owl:Class ;
  rdfs:label "Total length measurement"@en ;
  rdfs:subClassOf smn:FishLengthMeasurementType .

smn:IndividualMeasurement a owl:Class ;
  rdfs:label "Individual measurement"@en ;
  rdfs:subClassOf smn:Measurement .

smn:ModelMeasurement a owl:Class ;
  rdfs:label "Model measurement"@en ;
  rdfs:subClassOf smn:Measurement .

smn:AggregatedMeasurement a owl:Class ;
  rdfs:label "Aggregated measurement"@en ;
  rdfs:subClassOf smn:Measurement ,
    [ a owl:Restriction ;
      owl:onProperty smn:basedOn ;
      owl:someValuesFrom smn:EnumerationMethod ] .

smn:SamplingEvent a owl:Class ;
  rdfs:label "Sampling event"@en ;
  rdfs:comment "A sampling activity that targets a geographic feature, yields a sample, and records a time."@en ;
  rdfs:subClassOf sosa:Sampling ,
    [ a owl:Restriction ;
      owl:onProperty sosa:hasFeatureOfInterest ;
      owl:someValuesFrom geosparql:Feature ],
    [ a owl:Restriction ;
      owl:onProperty sosa:hasResult ;
      owl:someValuesFrom sosa:Sample ],
    [ a owl:Restriction ;
      owl:onProperty sosa:resultTime ;
      owl:someValuesFrom time:Instant ] .

sosa:FeatureOfInterest sosa:hasSample sosa:Sample .
sosa:Sample sosa:isResultOf sosa:Sampling .

obo:NCBITaxon_8018 rdfs:subClassOf obo:NCBITaxon_8015 .

smn:NCBITaxon_8018 a owl:Class ;
  rdfs:label "Oncorhynchus keta proxy class"@en ;
  rdfs:subClassOf obo:NCBITaxon_8018 .

#################################################################
# Reusable escapement and survey terms (migrated from gcdfo)
#################################################################

smn:Escapement a owl:Class ;
  rdfs:label "Escapement"@en ;
  iao:0000115 "The number of mature salmon that pass through (or escape) fisheries and return to fresh water to spawn."@en ;
  rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> .

smn:SurveyEvent a owl:Class ;
  rdfs:label "Survey event"@en ;
  iao:0000115 "A field event that collects information about fish populations to evaluate status and support management decisions."@en ;
  rdfs:subClassOf dwc:Event .

smn:EscapementSurveyEvent a owl:Class ;
  rdfs:label "Escapement survey event"@en ;
  iao:0000115 "A survey event specifically for estimating escapement."@en ;
  rdfs:subClassOf smn:SurveyEvent .

smn:EscapementMeasurement a owl:Class ;
  rdfs:label "Escapement measurement"@en ;
  iao:0000115 "A measurement or estimate of escapement tied to a stock and a survey event."@en ;
  rdfs:subClassOf iao:0000109 .

#################################################################
# Properties used by observations and event models
#################################################################

smn:hasMeasurement a owl:ObjectProperty ;
  rdfs:label "has measurement"@en ;
  rdfs:domain sosa:FeatureOfInterest ;
  rdfs:range smn:Measurement .

smn:observedTaxonFamily a owl:ObjectProperty ;
  rdfs:label "observed taxon family"@en ;
  rdfs:domain sosa:Observation ;
  rdfs:range obo:NCBITaxon_8015 .

smn:observedTaxonSpecies a owl:ObjectProperty ;
  rdfs:label "observed taxon species"@en ;
  rdfs:domain sosa:Observation ;
  rdfs:range obo:NCBITaxon_8018 .

smn:hasEventType a owl:ObjectProperty ;
  rdfs:label "has event type"@en ;
  rdfs:domain smn:SamplingEvent ;
  rdfs:range smn:EventType .

smn:basedOn a owl:ObjectProperty ;
  rdfs:label "based on"@en ;
  rdfs:domain smn:AggregatedMeasurement ;
  rdfs:range smn:EnumerationMethod .

smn:characteristicFor a owl:ObjectProperty ;
  rdfs:label "characteristic for"@en ;
  rdfs:domain sosa:Property ;
  rdfs:range sosa:FeatureOfInterest .
