@prefix smn: <https://w3id.org/smn/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix iao: <http://purl.obolibrary.org/obo/IAO_> .

<https://w3id.org/smn/modules/04-management-governance> a owl:Ontology ;
  rdfs:label "Salmon Domain Ontology Module 04: Management and governance"@en ;
  rdfs:comment "Conservative shared event taxonomy. Policy/program-specific schemes remain in profile ontologies."@en .

#################################################################
# Event taxonomy
#################################################################

smn:EventType a owl:Class ;
  rdfs:label "Event type"@en ;
  iao:0000115 "A class used to categorize fisheries or survey event instances by operational type."@en ;
  rdfs:isDefinedBy <https://w3id.org/smn> .

smn:FishingType a owl:Class ;
  rdfs:label "Fishing type"@en ;
  rdfs:subClassOf smn:EventType ;
  rdfs:isDefinedBy <https://w3id.org/smn> .

smn:seiningEvent a owl:Class ;
  rdfs:label "Seining event"@en ;
  rdfs:subClassOf smn:FishingType ;
  rdfs:isDefinedBy <https://w3id.org/smn> .
