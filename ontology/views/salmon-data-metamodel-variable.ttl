@prefix smn:    <https://w3id.org/smn/> .
@prefix smnv:   <https://w3id.org/smn/views/salmon-data-metamodel#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix iadopt: <https://w3id.org/iadopt/ont/> .
@prefix iao:    <http://purl.obolibrary.org/obo/IAO_> .

<https://w3id.org/smn/views/salmon-data-metamodel/variable> a owl:Ontology ;
  rdfs:label "Salmon data metamodel view — variable slice"@en ;
  rdfs:comment "Variable-focused slice: how salmon teams often package entity + property + constraints/modifiers into the practical thing they call a variable."@en .

iadopt:Variable rdfs:subClassOf iao:0000030, sosa:Property .
iadopt:Constraint rdfs:subClassOf iao:0000030 .

smn:MetricBenchmark skos:closeMatch iadopt:Constraint .
smn:ReferencePoint skos:closeMatch iadopt:Constraint .
smn:LowerBiologicalBenchmark skos:closeMatch iadopt:Constraint .
smn:UpperBiologicalBenchmark skos:closeMatch iadopt:Constraint .

smnv:SalmonDataVariable a owl:Class ;
  rdfs:label "salmon data variable"@en ;
  rdfs:comment "A non-normative helper class for the common salmon-data pattern where a published variable bundles the entity of interest, the property of interest, and any important qualifiers or statistical modifiers."@en ;
  rdfs:subClassOf iadopt:Variable ,
    [ a owl:Restriction ; owl:onProperty smnv:variableRepresentsEntity ; owl:someValuesFrom iadopt:Entity ] ,
    [ a owl:Restriction ; owl:onProperty smnv:variableRepresentsProperty ; owl:someValuesFrom iadopt:Property ] .

smnv:variableRepresentsEntity a owl:ObjectProperty ;
  rdfs:label "variable represents entity"@en ;
  rdfs:comment "Links a variable decomposition to the entity or feature it is about."@en ;
  rdfs:domain iadopt:Variable ;
  rdfs:range iadopt:Entity .

smnv:variableRepresentsProperty a owl:ObjectProperty ;
  rdfs:label "variable represents property"@en ;
  rdfs:comment "Links a variable decomposition to the property or characteristic being described."@en ;
  rdfs:domain iadopt:Variable ;
  rdfs:range iadopt:Property .

smnv:variableUsesConstraint a owl:ObjectProperty ;
  rdfs:label "variable uses constraint"@en ;
  rdfs:comment "Adds qualifiers such as brood year, location, life stage, or benchmark framing when those are part of the variable definition rather than just row-level data values."@en ;
  rdfs:domain iadopt:Variable ;
  rdfs:range iadopt:Constraint .

smnv:variableUsesStatisticalModifier a owl:ObjectProperty ;
  rdfs:label "variable uses statistical modifier"@en ;
  rdfs:comment "Captures choices such as average, count, proportion, or confidence framing when they materially change the meaning of the published variable."@en ;
  rdfs:domain iadopt:Variable ;
  rdfs:range owl:Thing .

smnv:hasVariable a owl:ObjectProperty ;
  rdfs:label "has variable"@en ;
  rdfs:comment "Links an observation to the variable decomposition used in a salmon data workflow. In practice this is often managed as a compound term with decomposition annotations rather than a single pure OWL class."@en ;
  rdfs:domain sosa:Observation ;
  rdfs:range iadopt:Variable .

smnv:constraintConstrains a owl:ObjectProperty ;
  rdfs:label "constraint constrains"@en ;
  rdfs:subPropertyOf iadopt:constrains ;
  rdfs:domain iadopt:Constraint ;
  rdfs:range owl:Thing .

iadopt:Variable skos:closeMatch sosa:Property .
